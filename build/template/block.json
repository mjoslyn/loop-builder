{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "loop-builder/template",
  "version": "0.1.0",
  "title": "Loop Item Template",
  "category": "theme",
  "parent": [
    "loop-builder/query"
  ],
  "description": "Contains the design of one item. It is repeated for every result in the query.",
  "textdomain": "loop-builder",
  "usesContext": [
    "loop-builder/query",
    "loop-builder/queryId",
    "loop-builder/displayLayout",
    "loop-builder/cardStyle"
  ],
  "supports": {
    "reusable": false,
    "html": false,
    "align": false,
    "spacing": {
      "blockGap": {
        "__experimentalDefault": "1.25rem"
      }
    },
    "__experimentalLayout": false
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}