{
	"name": "loop-builder/loop-builder",
	"description": "A visual query loop builder for the WordPress block editor.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpunit/phpunit": "^11"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"lint:php": "phpcs",
		"lint:php:fix": "phpcbf",
		"test": "phpunit"
	}
}
